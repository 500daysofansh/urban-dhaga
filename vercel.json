{
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/sitemap.xml",   "destination": "/api/sitemap" },
    { "source": "/product/:id",   "destination": "/api/prerender?id=:id" },
    { "source": "/api/(.*)",      "destination": "/api/$1" },
    { "source": "/(.*)",          "destination": "/index.html" }
  ]
}
